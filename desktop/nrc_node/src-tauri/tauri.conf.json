{
    "build": {
      "beforeBuildCommand": "",  // 中文注释：构建前执行的命令（当前为空）
      "beforeDevCommand": "",    // 中文注释：开发模式前执行的命令（当前为空）
      "devPath": "../src-tauri", // 中文注释：开发模式下前端资源路径
      "distDir": "../src-tauri"  // 中文注释：构建完成后前端资源路径
    },
    "package": {
      "productName": "NRC Node", // 中文注释：应用名称，显示在打包后的程序中
      "version": "0.1.0"         // 中文注释：应用版本号，与 Cargo.toml 一致
    },
    "tauri": {
      "allowlist": {
        "all": true              // 中文注释：允许所有 Tauri API（开发时方便，生产环境应限制）
      },
      "windows": [
        {
          "title": "国储会节点", // 中文注释：窗口标题，显示在应用顶部
          "width": 800,          // 中文注释：窗口宽度（像素）
          "height": 600          // 中文注释：窗口高度（像素）
        }
      ]
    }
  }